# GitHub username used by the "GitHub Intelligence" dashboard for live stats
# (repositories, stars, followers) and the contribution heatmap.
# If unset or the user is not found, the section shows curated fallback data.
NEXT_PUBLIC_GITHUB_USERNAME=RajGauravTiwari
